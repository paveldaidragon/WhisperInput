# Whisper-PTT Configuration
# Copy this to .env or set env vars directly

# --- Hotkey ---
# Hold to record, release to transcribe.
# Single key: F9, F1, alt, space, enter
# Combo: ctrl+f9, alt+f9, shift+f9
WHISPER_PTT_HOTKEY=F9

# --- Language ---
# BCP-47 language code: ru, en, de, fr, es, etc.
WHISPER_PTT_LANGUAGE=ru

# --- Whisper Model ---
# tiny (74MB), base (142MB), small (466MB), medium (1.5GB), large-v3 (2.9GB)
WHISPER_PTT_MODEL=medium

# --- Output ---
# Paste text into active window (Ctrl+V)
WHISPER_PTT_PASTE=true

# Copy to clipboard
WHISPER_PTT_COPY_TO_CLIPBOARD=true

# Keys to send after paste (enter, ctrl+enter, or "none")
WHISPER_PTT_KEYS_AFTER_PASTE=none

# --- Backend ---
# Hotkey backend: keyboard, pynput, win32, auto
# auto = try win32 → keyboard → pynput
WHISPER_PTT_BACKEND=auto

# --- System Tray ---
# Run as tray app instead of CLI
WHISPER_PTT_TRAY=true

# --- Model Storage ---
# Where to cache downloaded models (default: %LOCALAPPDATA%\WhisperPTT\models)
# WHISPER_PTT_MODEL_DIR=
